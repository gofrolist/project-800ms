# Caddy reverse-proxy for project-800ms with automatic Let's Encrypt TLS.
#
# Fronts three hostnames + www redirect:
#   ${DOMAIN}         -> SPA (static files)
#   api.${DOMAIN}     -> api:8000     (FastAPI)
#   livekit.${DOMAIN} -> livekit:7880 (LiveKit signaling / WebSocket)
#   www.${DOMAIN}     -> 301 to ${DOMAIN}
#
# WebRTC media (UDP 50000-50099) bypasses Caddy entirely — the browser sends
# RTP directly to the instance's EIP. SRTP already encrypts media, so this
# is fine.
#
# The TLS_EMAIL env var is used for Let's Encrypt account registration so
# you get expiry notifications. DOMAIN is the base domain (e.g. voice.example.com).

{
	email {$TLS_EMAIL}

	# Uncomment to test against Let's Encrypt staging (avoids rate limits
	# while debugging DNS setup — certs will be untrusted).
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}

{$DOMAIN} {
	encode zstd gzip

	tls {
		protocols tls1.2 tls1.3
	}

	root * /srv/web

	# SPA fallback — serve index.html for client-side routes.
	try_files {path} /index.html
	file_server

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; connect-src 'self' https://api.{$DOMAIN} wss://livekit.{$DOMAIN}; script-src 'self'; style-src 'self' 'unsafe-inline'; media-src 'self' blob:"
		Permissions-Policy "microphone=(self), camera=(), geolocation=()"
		-Server
	}

	log {
		output stdout
		format console
	}
}

api.{$DOMAIN} {
	encode zstd gzip

	# Aggressive TLS — modern clients only.
	tls {
		protocols tls1.2 tls1.3
	}

	# FastAPI handles CORS itself (CORS_ALLOWED_ORIGINS in .env).
	reverse_proxy api:8000 {
		header_up Host {http.request.host}
		header_up X-Real-IP {http.request.remote.host}
		header_up X-Forwarded-For {http.request.remote.host}
		header_up X-Forwarded-Proto {http.request.scheme}
	}

	# Docs endpoints: Swagger/ReDoc/Scalar load JS+CSS from jsdelivr and the
	# FastAPI favicon from tiangolo.com, plus execute inline scripts. The
	# JSON endpoints don't need any of this, so we scope the loosened CSP
	# to /docs, /redoc, /reference with a matcher.
	@docs path /docs /docs/* /redoc /redoc/* /reference /reference/*
	@not_docs not path /docs /docs/* /redoc /redoc/* /reference /reference/*

	header @docs {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; connect-src 'self' wss:; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https://cdn.jsdelivr.net https://fastapi.tiangolo.com; font-src 'self' https://cdn.jsdelivr.net; worker-src 'self' blob:"
		Permissions-Policy "microphone=(self), camera=(), geolocation=()"
		-Server
	}

	# Everything else (JSON API surface) keeps the tight CSP.
	header @not_docs {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; connect-src 'self' wss:; script-src 'self'; style-src 'self' 'unsafe-inline'"
		Permissions-Policy "microphone=(self), camera=(), geolocation=()"
		-Server
	}

	log {
		output stdout
		format console
	}
}

livekit.{$DOMAIN} {
	tls {
		protocols tls1.2 tls1.3
	}

	# LiveKit uses long-lived WebSocket connections for signaling. Disable
	# Caddy's default proxy buffering and keep the connection open.
	reverse_proxy livekit:7880 {
		header_up Host {http.request.host}
		header_up X-Real-IP {http.request.remote.host}
		header_up X-Forwarded-For {http.request.remote.host}
		header_up X-Forwarded-Proto {http.request.scheme}

		# Give LiveKit room for slow WS handshakes.
		transport http {
			read_timeout 30s
			write_timeout 30s
		}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	log {
		output stdout
		format console
	}
}
