project_id   = "project-800ms-mvp"
project_name = "project-800ms"
region       = "us-central1"
zone         = "us-central1-a"
machine_type = "g2-standard-8"

# App source
git_repo = "https://github.com/gofrolist/project-800ms.git"
git_ref  = "main"

# GHCR image tag for api/agent. Use "latest" to follow main, or pin to
# "sha-abc1234" for a reproducible deploy / easy rollback.
image_tag = "latest"

# -----------------------------------------------------------------------------
# Spot vs on-demand
#
# GCP Spot VMs: ~60-70%% off on-demand. Preempted with 30s notice, boot disk
# preserved. No hard capacity failures like AWS spot.
# -----------------------------------------------------------------------------
use_spot = true

# -----------------------------------------------------------------------------
# TLS (strongly recommended)
#
# Leave both empty for a plaintext MVP demo on http://<ip>:8000 / ws://<ip>:7880.
# Set both to enable Caddy + Let's Encrypt, serving:
#   api.$domain     — FastAPI
#   livekit.$domain — LiveKit signaling (wss://)
# -----------------------------------------------------------------------------
domain    = ""  # e.g. "voice.example.com"
tls_email = ""  # e.g. "you@example.com"

# -----------------------------------------------------------------------------
# Cloudflare DNS automation (optional)
#
# Leave empty to manage DNS by hand. Set both to have Terraform create the
# api.$domain and livekit.$domain A records automatically.
#
# cloudflare_api_token — dash.cloudflare.com → My Profile → API Tokens →
#   "Edit zone DNS" template, scoped to the target zone only.
# cloudflare_zone_id   — CF dashboard → domain overview, right sidebar.
#
# Records are always proxied=false. Cloudflare's proxy cannot pass WebRTC UDP
# or Let's Encrypt HTTP-01 challenges.
# -----------------------------------------------------------------------------
cloudflare_api_token = ""
cloudflare_zone_id   = ""

# -----------------------------------------------------------------------------
# Secrets — generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
postgres_password      = "REPLACE_ME_openssl_rand_hex_32"
redis_password         = "REPLACE_ME_openssl_rand_hex_32"
livekit_api_key        = "REPLACE_ME"
livekit_api_secret     = "REPLACE_ME_openssl_rand_hex_32"
vllm_api_key           = "REPLACE_ME_openssl_rand_hex_32"
hugging_face_hub_token = ""  # optional; required only for gated HF models

# -----------------------------------------------------------------------------
# LLM provider (optional — default routes to local vLLM with Qwen-7B)
#
# Set all three to route the agent at an external OpenAI-compatible LLM.
# Local vllm container keeps running (wastes GPU but easy to flip back).
#
# Groq example (10-50x faster TTFT than local L4):
#   llm_base_url = "https://api.groq.com/openai/v1"
#   llm_model    = "llama-3.3-70b-versatile"
#   llm_api_key  = "gsk_..."  # https://console.groq.com/keys
#
# OpenAI example:
#   llm_base_url = "https://api.openai.com/v1"
#   llm_model    = "gpt-4o-mini"
#   llm_api_key  = "sk-..."
# -----------------------------------------------------------------------------
llm_base_url = ""
llm_model    = ""
llm_api_key  = ""

# -----------------------------------------------------------------------------
# API seed keys (optional, but required if you want the web SPA to work
# out of the box)
#
# When set, the Alembic seed migration materializes API keys for the
# pre-created "dev" and "demo" tenants. The raw values are hashed and
# discarded — this is the ONLY time they're recoverable, so save them.
#
# The web SPA uses SEED_DEMO_API_KEY by default (startup_script defaults
# WEB_API_KEY to it), so leaving seed_demo_api_key empty means the SPA
# service will refuse to start (WEB_API_KEY is required in compose).
#
# Recommended: set seed_demo_api_key to a `tk_`-prefixed 32-byte hex —
#   openssl rand -hex 32 | xargs -I{} echo "tk_{}"
# Leave seed_dev_api_key empty unless you use the 'dev' tenant directly.
# -----------------------------------------------------------------------------
seed_demo_api_key = ""  # e.g. "tk_0123...abcd" — powers the web SPA
seed_dev_api_key  = ""

# -----------------------------------------------------------------------------
# LiveKit webhook signing (optional)
#
# Defaults to livekit_api_secret when empty. Set only when you need to
# rotate webhook auth independently of the JWT signing key.
# -----------------------------------------------------------------------------
webhook_signing_secret = ""

# -----------------------------------------------------------------------------
# Access
# -----------------------------------------------------------------------------
allowed_app_cidr = "0.0.0.0/0"

# Leave allowed_ssh_cidr empty to rely on gcloud OS Login + IAP tunneling
# (no public SSH port). Set to a CIDR only if you need raw SSH from elsewhere.
allowed_ssh_cidr = ""
