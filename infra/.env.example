# Copy to infra/.env and edit. Never commit the real .env.
#
# All values below MUST be replaced before any non-localhost deployment.
# Generate strong secrets with:  openssl rand -hex 32

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=voice
POSTGRES_PASSWORD=REPLACE_ME_openssl_rand_hex_32
POSTGRES_DB=voice

# ── LiveKit ─────────────────────────────────────────────────────────────────
# These are injected into the LiveKit server via LIVEKIT_KEYS env var (see
# docker-compose.yml) and used by the api/agent services to mint JWTs.
# The api key is a short identifier; the secret signs HMAC tokens and must
# be at least 32 characters (Settings validation enforces this).
LIVEKIT_API_KEY=REPLACE_ME_short_identifier
LIVEKIT_API_SECRET=REPLACE_ME_openssl_rand_hex_32

# Public URL browsers connect to. For local dev on the same machine use
# ws://localhost:7880. For a remote dev box, set to ws://<host-ip>:7880.
# For prod, wss://voice.yourdomain.com.
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# ⚠️  DANGER: --dev disables ALL admin API authentication on port 7880.
# Anyone can delete rooms, mute participants, disconnect users.
# ONLY use on localhost for debugging. NEVER set in any deployment.
# LIVEKIT_DEV_FLAG=--dev

# ── vLLM ────────────────────────────────────────────────────────────────────
# vLLM authenticates every request against this key. Pass to clients via
# `Authorization: Bearer <VLLM_API_KEY>`. The agent reads it from env.
VLLM_API_KEY=REPLACE_ME_openssl_rand_hex_32

# ── Hugging Face ────────────────────────────────────────────────────────────
# Only required if you use gated models. Qwen2.5-7B-Instruct-AWQ is public,
# but setting a token avoids rate limits on first download.
HUGGING_FACE_HUB_TOKEN=

# ── TTS engine selector ─────────────────────────────────────────────────────
# Fallback TTS engine when a session does NOT set `tts_engine` on
# POST /v1/sessions. "piper" (CPU, default), "silero" (GPU), "qwen3"
# (sidecar GPU). Per-session overrides from the API take precedence, so
# the demo site's three-button selector can route each call to a
# different backend without restarting the agent.
TTS_ENGINE=piper

# Comma-separated list of engines to pre-load at agent startup. Silero is
# the only engine with an agent-side preload cost (torch.hub model fetch
# ~200 MB); listing it here makes Silero-backed sessions ready immediately.
# Piper loads lazily, Qwen3 lives in the sidecar container. Defaults to
# the TTS_ENGINE value so single-engine operators keep old behavior. For
# the three-button demo, set:
#   TTS_PRELOAD_ENGINES=piper,silero,qwen3
#   COMPOSE_PROFILES=local-llm,tts-qwen3
TTS_PRELOAD_ENGINES=piper

# ── TTS voice (Piper) ───────────────────────────────────────────────────────
# Russian Piper voice for TTS output. Auto-downloads on first use.
# Available voices: ru_RU-ruslan-medium, ru_RU-irina-medium,
#                   ru_RU-denis-medium, ru_RU-dmitri-medium
# See https://github.com/rhasspy/piper/blob/master/VOICES.md
# Interpreted per-engine: Piper reads a voice-pack name; Silero reads a
# speaker id (e.g. "v5_cis_base"); OpenAI-compat sidecars (Qwen3) read an
# OpenAI voice name ("alloy" / "echo" / "fable" / "nova" / "onyx" /
# "shimmer" / etc.) — when TTS_ENGINE=qwen3 and this value isn't in the
# OpenAI whitelist, the factory substitutes "echo" and logs a warning.
TTS_VOICE=ru_RU-denis-medium

# ── Qwen3-TTS sidecar (TTS_ENGINE=qwen3) ────────────────────────────────────
# The Qwen3-TTS community wrapper runs as a compose sidecar (profile
# tts-qwen3 — see infra/docker-compose.yml). These vars wire the agent to
# the sidecar's OpenAI-compat endpoint. Leave empty when TTS_ENGINE is
# "piper" or "silero"; the factory only validates non-empty at dispatch
# time when TTS_ENGINE=qwen3.
#
# Internal docker-network URL. Keep the default for in-compose use; point
# elsewhere if the sidecar ever moves off-box. Must end with /v1 —
# Pipecat's OpenAITTSService appends /audio/speech itself.
QWEN3_TTS_BASE_URL=http://qwen3-tts:8000/v1

# Shared secret between the sidecar and the agent. The sidecar's wrapper
# doesn't enforce this by default, but we keep parity with VLLM_API_KEY so
# future wrapper versions or upstream auth-middleware additions Just Work.
# Generate with: openssl rand -hex 32
QWEN3_TTS_API_KEY=REPLACE_ME_openssl_rand_hex_32

# Which Qwen3-TTS variant the sidecar serves. Maps to config.yaml's
# `default_model` in infra/qwen3-tts-wrapper/config.yaml. 0.6B-Base is the
# plan's committed default; flip to 1.7B-Base only after the Unit 5 VRAM
# co-residency bench confirms headroom under vLLM + GigaAM load.
QWEN3_VARIANT=0.6B-Base

# ── API CORS ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, OR ["*"] for fully open (dev only).
# In prod, set to your frontend origin(s) explicitly. Pydantic-settings parses
# this as a JSON list when wrapped in brackets, or as a comma list otherwise.
CORS_ALLOWED_ORIGINS=["*"]

# ── IP-based rate limits (defense-in-depth, tunable per deploy) ─────────────
# Cap per source IP per minute on unauthenticated surfaces. The real
# security boundary is the admin key itself and LiveKit JWT signatures;
# these limits just prevent online brute-force / JWT-flood CPU burn.
#
# Raise ADMIN_IP_RATE_PER_MINUTE if you run bulk admin automation from a
# shared egress IP (Terraform for_each over many tenants, CI seeding,
# nightly key rotation). 60/min is fine for a human operator; 300-600 is
# comfortable for scripted workflows. Against a 256-bit admin key the
# cap is advisory, not load-bearing.
#
# Raise WEBHOOK_IP_RATE_PER_MINUTE if LiveKit's webhook path starts 429-ing
# under real traffic — e.g. many concurrent rooms from one LiveKit egress.
# Watch http_requests_total{path="/v1/livekit-webhook",status="429"} on
# the /metrics endpoint.
ADMIN_IP_RATE_PER_MINUTE=60
WEBHOOK_IP_RATE_PER_MINUTE=1000

# ── Logging ─────────────────────────────────────────────────────────────────
# Agent log level. INFO by default. DEBUG logs full STT transcripts and LLM
# prompts/completions, which is a privacy issue if logs are aggregated.
LOG_LEVEL=INFO

# ── Agent base image ────────────────────────────────────────────────────────
# The agent uses a split image strategy: a heavy BASE image
# (services/agent/Dockerfile.base) carries CUDA + Python deps, and the
# thin application Dockerfile just COPYs source on top. Override this to
# pin a registry-hosted base by digest in prod, e.g.
#   AGENT_BASE_IMAGE=ghcr.io/<owner>/project-800ms-agent-base@sha256:…
# For local dev, build once with:
#   docker build -f services/agent/Dockerfile.base \
#     -t project-800ms-agent-base:local services/agent/
# AGENT_BASE_IMAGE=project-800ms-agent-base:local

# ── Web SPA API key ─────────────────────────────────────────────────────────
# The demo SPA embeds this key and sends it as X-API-Key on every
# /v1/sessions call. Required whenever the TLS overlay is active.
#
# Treat this value as PUBLIC — anyone who opens the page can read it from
# the built JS bundle. The security boundary is the tenant's
# `allowed_origins` column (Phase 1g): set it to your SPA's domain only, so
# a leaked key can't be abused from another origin.
#
# For local dev without TLS, export WEB_API_KEY locally when running the
# SPA against a real backend. Not required when web is not started.
WEB_API_KEY=

# ── Seed API key ────────────────────────────────────────────────────────────
# When set, the 0002_seed_demo_tenant Alembic migration materializes an API
# key for the 'demo' tenant (used by the public web SPA). Leave empty in
# deployments that provision keys through a separate admin flow.
#
# IMPORTANT: this is the only time the raw key is known to the system. The
# migration hashes + discards the raw string. If you lose it, rotate via SQL
# (UPDATE api_keys SET revoked_at = now() WHERE ..., then insert a new row
# with the new hash).
SEED_DEMO_API_KEY=

# ── API cache ───────────────────────────────────────────────────────────────
# How long the API caches an X-API-Key → tenant lookup (seconds). Shorter =
# faster revocation propagation, more DB load. 60s is the default.
TENANT_CACHE_TTL_SECONDS=60

# ── Agent internal token ────────────────────────────────────────────────────
# Shared secret for server-to-server calls between the agent and api
# (currently: transcript writes to POST /internal/transcripts).
# Empty disables transcript persistence; the agent still forwards
# transcripts over LiveKit's data channel to the web UI.
# Generate with: openssl rand -hex 32
AGENT_INTERNAL_TOKEN=

# ── Admin API key ───────────────────────────────────────────────────────────
# Master key for /v1/admin/* operations (create tenants, issue / revoke
# API keys). NOT a tenant key — it bypasses tenant scoping entirely, so
# guard it as the highest-privilege credential in the system.
# Empty disables the admin API surface.
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=
