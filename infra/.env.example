# Copy to infra/.env and edit. Never commit the real .env.

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=voice
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=voice

# ── LiveKit ─────────────────────────────────────────────────────────────────
# These must match the `keys:` entry in infra/livekit.yaml.
# For dev, the default key name is `devkey` with the secret below.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_at_least_32_characters_long_xxxxxx

# Public URL browsers connect to. For local dev on the same machine use ws://localhost:7880.
# For a remote dev box, set to ws://<host-ip>:7880. For prod, wss://voice.yourdomain.com.
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# Single-tenant demo room name — API + agent must agree.
DEMO_ROOM=demo

# ── Hugging Face ────────────────────────────────────────────────────────────
# Only required if you use gated models. Qwen2.5-7B-Instruct-AWQ is public,
# but setting a token avoids rate limits on first download.
HUGGING_FACE_HUB_TOKEN=

# ── TTS voice (Piper) ───────────────────────────────────────────────────────
# Russian voices: ru_RU-ruslan-medium, ru_RU-irina-medium, ru_RU-denis-medium, ru_RU-dmitri-medium
# English voices: en_US-ryan-high, en_US-amy-medium, en_GB-alan-medium
# Auto-downloads on first use. See https://github.com/rhasspy/piper/blob/master/VOICES.md
TTS_VOICE=ru_RU-ruslan-medium
