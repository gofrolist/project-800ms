# Copy to infra/.env and edit. Never commit the real .env.
#
# All values below MUST be replaced before any non-localhost deployment.
# Generate strong secrets with:  openssl rand -hex 32

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=voice
POSTGRES_PASSWORD=REPLACE_ME_openssl_rand_hex_32
POSTGRES_DB=voice

# ── LiveKit ─────────────────────────────────────────────────────────────────
# These are injected into the LiveKit server via LIVEKIT_KEYS env var (see
# docker-compose.yml) and used by the api/agent services to mint JWTs.
# The api key is a short identifier; the secret signs HMAC tokens and must
# be at least 32 characters (Settings validation enforces this).
LIVEKIT_API_KEY=REPLACE_ME_short_identifier
LIVEKIT_API_SECRET=REPLACE_ME_openssl_rand_hex_32

# Public URL browsers connect to. For local dev on the same machine use
# ws://localhost:7880. For a remote dev box, set to ws://<host-ip>:7880.
# For prod, wss://voice.yourdomain.com.
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# ⚠️  DANGER: --dev disables ALL admin API authentication on port 7880.
# Anyone can delete rooms, mute participants, disconnect users.
# ONLY use on localhost for debugging. NEVER set in any deployment.
# LIVEKIT_DEV_FLAG=--dev

# ── vLLM ────────────────────────────────────────────────────────────────────
# vLLM authenticates every request against this key. Pass to clients via
# `Authorization: Bearer <VLLM_API_KEY>`. The agent reads it from env.
VLLM_API_KEY=REPLACE_ME_openssl_rand_hex_32

# ── Hugging Face ────────────────────────────────────────────────────────────
# Only required if you use gated models. Qwen2.5-7B-Instruct-AWQ is public,
# but setting a token avoids rate limits on first download.
HUGGING_FACE_HUB_TOKEN=

# ── TTS voice (Piper) ───────────────────────────────────────────────────────
# Russian Piper voice for TTS output. Auto-downloads on first use.
# Available voices: ru_RU-ruslan-medium, ru_RU-irina-medium,
#                   ru_RU-denis-medium, ru_RU-dmitri-medium
# See https://github.com/rhasspy/piper/blob/master/VOICES.md
TTS_VOICE=ru_RU-denis-medium

# ── API CORS ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, OR ["*"] for fully open (dev only).
# In prod, set to your frontend origin(s) explicitly. Pydantic-settings parses
# this as a JSON list when wrapped in brackets, or as a comma list otherwise.
CORS_ALLOWED_ORIGINS=["*"]

# ── Logging ─────────────────────────────────────────────────────────────────
# Agent log level. INFO by default. DEBUG logs full STT transcripts and LLM
# prompts/completions, which is a privacy issue if logs are aggregated.
LOG_LEVEL=INFO

# ── Web SPA API key ─────────────────────────────────────────────────────────
# The demo SPA embeds this key and sends it as X-API-Key on every
# /v1/sessions call. Required whenever the TLS overlay is active.
#
# Treat this value as PUBLIC — anyone who opens the page can read it from
# the built JS bundle. The security boundary is the tenant's
# `allowed_origins` column (Phase 1g): set it to your SPA's domain only, so
# a leaked key can't be abused from another origin.
#
# For local dev without TLS, export WEB_API_KEY locally when running the
# SPA against a real backend. Not required when web is not started.
WEB_API_KEY=

# ── Seed API key ────────────────────────────────────────────────────────────
# When set, the 0002_seed_demo_tenant Alembic migration materializes an API
# key for the 'demo' tenant (used by the public web SPA). Leave empty in
# deployments that provision keys through a separate admin flow.
#
# IMPORTANT: this is the only time the raw key is known to the system. The
# migration hashes + discards the raw string. If you lose it, rotate via SQL
# (UPDATE api_keys SET revoked_at = now() WHERE ..., then insert a new row
# with the new hash).
SEED_DEMO_API_KEY=

# ── API cache ───────────────────────────────────────────────────────────────
# How long the API caches an X-API-Key → tenant lookup (seconds). Shorter =
# faster revocation propagation, more DB load. 60s is the default.
TENANT_CACHE_TTL_SECONDS=60
