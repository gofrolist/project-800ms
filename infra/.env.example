# Copy to infra/.env and edit. Never commit the real .env.
#
# All values below MUST be replaced before any non-localhost deployment.
# Generate strong secrets with:  openssl rand -hex 32

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=voice
POSTGRES_PASSWORD=REPLACE_ME_openssl_rand_hex_32
POSTGRES_DB=voice

# ── Redis ───────────────────────────────────────────────────────────────────
# Required even on loopback — Redis without auth is a known ransomware vector.
REDIS_PASSWORD=REPLACE_ME_openssl_rand_hex_32

# ── LiveKit ─────────────────────────────────────────────────────────────────
# These are injected into the LiveKit server via LIVEKIT_KEYS env var (see
# docker-compose.yml) and used by the api/agent services to mint JWTs.
# The api key is a short identifier; the secret signs HMAC tokens and must
# be at least 32 characters (Settings validation enforces this).
LIVEKIT_API_KEY=REPLACE_ME_short_identifier
LIVEKIT_API_SECRET=REPLACE_ME_openssl_rand_hex_32

# Public URL browsers connect to. For local dev on the same machine use
# ws://localhost:7880. For a remote dev box, set to ws://<host-ip>:7880.
# For prod, wss://voice.yourdomain.com.
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# Optional: enable LiveKit's --dev flag for local testing only. NEVER set
# this in any non-localhost deployment — it disables admin API auth on
# port 7880, allowing anyone to delete rooms / mute participants / etc.
# LIVEKIT_DEV_FLAG=--dev

# Single-tenant demo room name — API + agent must agree.
DEMO_ROOM=demo

# ── vLLM ────────────────────────────────────────────────────────────────────
# vLLM authenticates every request against this key. Pass to clients via
# `Authorization: Bearer <VLLM_API_KEY>`. The agent reads it from env.
VLLM_API_KEY=REPLACE_ME_openssl_rand_hex_32

# ── Hugging Face ────────────────────────────────────────────────────────────
# Only required if you use gated models. Qwen2.5-7B-Instruct-AWQ is public,
# but setting a token avoids rate limits on first download.
HUGGING_FACE_HUB_TOKEN=

# ── TTS voices (Piper) ──────────────────────────────────────────────────────
# Two voices loaded simultaneously, one per supported output language. The
# agent's bilingual router (services/agent/lang.py) detects the language of
# each LLM output and routes to the matching voice.
#
# English voices: en_US-amy-medium, en_US-ryan-high, en_GB-alan-medium
# Russian voices: ru_RU-ruslan-medium, ru_RU-irina-medium, ru_RU-denis-medium,
#                 ru_RU-dmitri-medium
# Auto-downloads on first use. See https://github.com/rhasspy/piper/blob/master/VOICES.md
TTS_VOICE_EN=en_US-amy-medium
TTS_VOICE_RU=ru_RU-denis-medium

# ── API CORS ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, OR ["*"] for fully open (dev only).
# In prod, set to your frontend origin(s) explicitly. Pydantic-settings parses
# this as a JSON list when wrapped in brackets, or as a comma list otherwise.
CORS_ALLOWED_ORIGINS=["*"]

# ── Logging ─────────────────────────────────────────────────────────────────
# Agent log level. INFO by default. DEBUG logs full STT transcripts and LLM
# prompts/completions, which is a privacy issue if logs are aggregated.
LOG_LEVEL=INFO
